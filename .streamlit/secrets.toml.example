# Renomeie para secrets.toml em DEV LOCAL (NÃO commitar!)
# No Streamlit Community Cloud: cole esse conteúdo em
# App settings → Secrets (interface web)

[postgres]
# Exemplo Neon: postgresql://user:pass@ep-abc-123.us-east-2.aws.neon.tech/estoque_pdv?sslmode=require
# Exemplo Supabase: postgresql://postgres:senha@db.xxxxx.supabase.co:5432/postgres
url = "postgresql://usuario:senha@host:5432/banco?sslmode=require"

[app]
# Nome da instância (útil se rodar múltiplos eventos)
instance_name = "VI Despertar 2026"
# Secret aleatório pra possíveis assinaturas de cookie no futuro
session_secret = "troque-isso-por-um-valor-aleatorio-longo"
